{% extends "layout.njk" %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">

    {% if error == 'empty' %}
      {{ govukErrorSummary({
        titleText: "There is a problem",
        errorList: [
          { text: "Enter a name or National Insurance number", href: "#searchTerm" }
        ]
      }) }}
    {% endif %}

    <h1 class="govuk-heading-xl">Find someone</h1>
    
    <form action="/search" method="post">
      {{ govukInput({
        label: {
          text: "Search by National Insurance number or name",
          classes: "govuk-label--l",
          isPageHeading: false
        },
        hint: {
          text: "For example, QQ123456C or Jane Doe"
        },
        id: "searchTerm",
        name: "searchTerm",
        errorMessage: { text: "Enter a valid search term" } if error == 'empty' else null
      }) }}

      {{ govukButton({
        text: "Search"
      }) }}
    </form>

  </div>
</div>
{% endblock %}